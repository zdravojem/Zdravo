SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-qr-url-updates
ZDRAVO_PUBLIC_RECIPE_BASE_URL=https://recipes.your-domain.com
ZDRAVO_PUBLIC_RECIPE_AUTO_DOWNLOAD=true

# Gmail recipe email sending
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=your-16-character-gmail-app-password
GMAIL_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-google-oauth-refresh-token

# Cloudflare R2 / S3-compatible recipe QR page upload
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ENDPOINT=https://your-cloudflare-account-id.r2.cloudflarestorage.com
# For EU jurisdiction buckets, use:
# R2_ENDPOINT=https://your-cloudflare-account-id.eu.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-r2-bucket-name
R2_PUBLIC_BASE_URL=https://recipes.your-domain.com
R2_RECIPE_PREFIX=recipes
R2_IMAGE_CACHE_CONTROL=public, max-age=300
ZDRAVO_RECIPE_QR_IMAGE_MODE=r2-url
R2_RECIPE_IMAGE_PREFIX=recipe-images
R2_INGREDIENT_IMAGE_PREFIX=ingredient-images
R2_RECIPE_IMAGE_TEMPLATE=
R2_INGREDIENT_IMAGE_TEMPLATE=
RECIPE_QR_WEBHOOK_SECRET=shared-secret-between-database-webhook-and-edge-function

# These Cloudflare-style aliases are also supported:
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_R2_ENDPOINT=https://your-cloudflare-account-id.r2.cloudflarestorage.com
CF_R2_ACCESS_KEY_ID=your-r2-access-key-id
CF_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CF_R2_BUCKET=your-r2-bucket-name
CF_PUBLIC_BASE_URL=https://recipes.your-domain.com
CF_R2_RECIPE_IMAGE_PREFIX=recipe-images
CF_R2_INGREDIENT_IMAGE_PREFIX=ingredient-images
CF_R2_RECIPE_IMAGE_TEMPLATE=
CF_R2_INGREDIENT_IMAGE_TEMPLATE=
