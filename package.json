{
  "name": "zdravo-jem",
  "version": "1.0.0",
  "description": "Zdravo Jem kiosk app",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^32.1.2",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "si.zdravo.jem",
    "productName": "Zdravo Jem",
    "icon": "assets/icons/zdravo-jem-icon.ico",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icons/zdravo-jem-icon.ico"
    }
  }
}
